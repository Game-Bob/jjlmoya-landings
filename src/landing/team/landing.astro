---
import type { KnownLocale } from '../../types';
import TeamHero from './components/TeamHero.astro';
import CompanyWorks from './components/CompanyWorks.astro';
import TeamComicScenes from './components/TeamComicScenes.astro';
import BehindJoke from './components/BehindJoke.astro';
import TranslationComic from './components/TranslationComic.astro';
import ProductManifesto from './components/ProductManifesto.astro';
import MemoryWall from './components/MemoryWall.astro';
import SupportTransition from './components/SupportTransition.astro';
import './styles/team-landing.css';

interface Props {
    locale: KnownLocale;
}

const { locale } = Astro.props;
---
<div class="team-landing" data-locale={locale}>
    <TeamHero />
    <CompanyWorks />
    <TeamComicScenes />
    <BehindJoke />
    <TranslationComic />
    <ProductManifesto />
    <MemoryWall />
    <SupportTransition locale={locale} />
</div>
