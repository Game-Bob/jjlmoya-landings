---
import '../styles/TranslationComic.css';

interface Props {
    t: {
        eyebrow: string;
        title: string;
        spainFood: string;
        worldFood: string;
        humanAssignment: string;
        languagesLabel: string;
        text: string;
        quote: string;
    };
}

const { t } = Astro.props;

const languages = ['EN', 'ES', 'FR', 'DE', 'IT', 'PT', 'NL', 'JA', 'KO', 'ZH'];
---

<section class="team-section translation-comic" aria-labelledby="translation-comic-title">
    <div class="team-landing-inner">
        <p class="team-section-eyebrow">{t.eyebrow}</p>
        <h2 class="team-section-title" id="translation-comic-title">{t.title}</h2>
        <div class="translation-comic-sequence">
            <div class="translation-comic-frame">
                <span class="translation-comic-bob">B</span>
                <p>{t.spainFood}</p>
            </div>
            <div class="translation-comic-frame">
                <span class="translation-comic-globe"></span>
                <p>{t.worldFood}</p>
            </div>
            <div class="translation-comic-frame">
                <span class="translation-comic-human">J</span>
                <p>{t.humanAssignment}</p>
            </div>
        </div>
        <div class="translation-comic-languages" aria-label={t.languagesLabel}>
            {languages.map((language) => <span>{language}</span>)}
        </div>
        <p class="team-section-text">
            {t.text}
        </p>
        <p class="translation-comic-quote">{t.quote}</p>
    </div>
</section>
