---
import '../styles/TranslationComic.css';

const languages = ['EN', 'ES', 'FR', 'DE', 'IT', 'PT', 'NL', 'JA', 'KO', 'ZH'];
---

<section class="team-section translation-comic" aria-labelledby="translation-comic-title">
    <div class="team-landing-inner">
        <p class="team-section-eyebrow">The translation comic</p>
        <h2 class="team-section-title" id="translation-comic-title">Bob saw the world map and made a business decision.</h2>
        <div class="translation-comic-sequence">
            <div class="translation-comic-frame">
                <span class="translation-comic-bob">B</span>
                <p>Spain means food.</p>
            </div>
            <div class="translation-comic-frame">
                <span class="translation-comic-globe"></span>
                <p>The world means more food.</p>
            </div>
            <div class="translation-comic-frame">
                <span class="translation-comic-human">J</span>
                <p>The human understands the assignment.</p>
            </div>
        </div>
        <div class="translation-comic-languages" aria-label="Supported language placeholders">
            {languages.map((language) => <span>{language}</span>)}
        </div>
        <p class="team-section-text">
            GameBob is translated with AI assistance. I do not speak every language on Earth. I prefer making the tools available worldwide, even if some translations are imperfect, rather than keeping everything locked in one language.
        </p>
        <p class="translation-comic-quote">More languages. More humans. More food.</p>
    </div>
</section>
