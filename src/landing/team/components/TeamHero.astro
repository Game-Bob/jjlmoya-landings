---
import heroSceneUrl from "../assets/gamebob-team-hero.webp";

interface Props {
    t: {
        kicker: string;
        titlePrefix: string;
        titleAccent: string;
        lead: string;
        stageLabel: string;
        sceneAlt: string;
    };
}

const { t } = Astro.props;
---

<section class="team-hero" aria-labelledby="team-hero-title">
    <div class="team-landing-inner team-hero-grid">
        <div class="team-hero-copy">
            <div class="team-hero-kicker">
                <span class="team-hero-dot" aria-hidden="true"></span>
                {t.kicker}
            </div>
            <slot name="title" />
            <p class="team-hero-lead">{t.lead}</p>
        </div>
        <div class="team-hero-stage">
            <div class="team-hero-window" aria-label={t.stageLabel}>
                <div class="team-hero-window-header">
                    <div class="team-hero-window-dots">
                        <span class="window-dot red"></span>
                        <span class="window-dot yellow"></span>
                        <span class="window-dot green"></span>
                    </div>
                    <span class="team-hero-window-title">gamebob_studio.webp</span>
                </div>
                <div class="team-hero-window-content">
                    <img
                        class="team-hero-scene"
                        src={heroSceneUrl.src}
                        width={heroSceneUrl.width}
                        height={heroSceneUrl.height}
                        alt={t.sceneAlt}
                        loading="eager"
                    />
                </div>
            </div>
        </div>
    </div>
</section>
