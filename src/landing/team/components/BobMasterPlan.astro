---
import "../styles/BobMasterPlan.css";
import MasterPlanScene from "./MasterPlanScene.astro";
import scene1 from "../assets/webcomic/scene-1.webp";
import scene2 from "../assets/webcomic/scene-2.webp";
import scene3 from "../assets/webcomic/scene-3.webp";
import scene4 from "../assets/webcomic/scene-4.webp";
import formulaMoney from "../assets/master-plan-money.webp";
import formulaFood from "../assets/master-plan-food.webp";
import formulaMoreMoney from "../assets/master-plan-more-money.webp";
import formulaMoreFood from "../assets/master-plan-more-food.webp";
import formulaTools from "../assets/master-plan-tools.webp";
import formulaProjects from "../assets/master-plan-projects.webp";

interface Props {
    t: {
        eyebrow: string;
        title: string;
        spainFood: string;
        worldFood: string;
        humanAssignment: string;
        languagesLabel: string;
        text: string;
        quote: string;
    };
}

const { t } = Astro.props;

const scenes = [
    {
        number: "01",
        label: "Mi gran error",
        title: "Bob descubrió el sistema.",
        text: "Un día cometí un error irreparable: le dejé ver cómo conseguía su comida. Ese día Bob lo empezó a entender todo.",
        visual: "money",
        asset: scene1,
        assetAlt: "",
        formula: [
            { label: "Dinero", asset: formulaMoney },
            { label: "Comida", asset: formulaFood },
        ],
    },
    {
        number: "02",
        label: "El sueño",
        title: "El estómago marcó el rumbo.",
        text: "Bob soñó día y noche sin parar y llegó a la conclusión de que si le gustaría tener muchísima más comida.",
        visual: "bowl",
        asset: scene2,
        assetAlt: "",
        formula: [
            { label: "Más dinero", asset: formulaMoreMoney },
            { label: "Más comida", asset: formulaMoreFood },
        ],
    },
    {
        number: "03",
        label: "El plan maestro",
        title: "Bob pensó en ingresos.",
        text: "Bob no se conformó con entender el sistema. Empezó a preguntarse cómo producir dinero de forma recurrente, preferiblemente sin mover una pata.",
        visual: "map",
        asset: scene3,
        assetAlt: "",
        formula: [
            { label: "Herramientas", asset: formulaTools },
            { label: "Dinero", asset: formulaMoney },
        ],
    },
    {
        number: "04",
        label: "Nace GameBob",
        title: "El humano recibió la orden.",
        text: "La orden fue sencilla: el humano construiría herramientas, juegos y páginas. Bob supervisaría la estrategia. La comida financiaría la visión.",
        visual: "orders",
        asset: scene4,
        assetAlt: "",
        formula: [
            { label: "Más proyectos", asset: formulaProjects },
            { label: "Más comida", asset: formulaMoreFood },
        ],
    },
];


---

<section class="team-section master-plan" aria-labelledby="master-plan-title">
    <div class="team-landing-inner">
        <div class="master-plan-header">
            <p class="team-section-eyebrow">{t.eyebrow}</p>
            <h2 class="team-section-title" id="master-plan-title">
                Cómo empezó todo
            </h2>
            <p class="team-section-text">
                El Plan Maestro de Bob para apoderarse de tu dinero empezó con
                una revelación sencilla: el dinero podía convertirse en comida.
                Desde entonces, nada volvió a ser operacionalmente seguro.
            </p>
        </div>

        <div class="master-plan-strip" aria-label={t.languagesLabel}>
            {
                scenes.map((scene) => (
                    <MasterPlanScene scene={scene} />
                ))
            }
        </div>

        <p class="master-plan-punchline">
            <span>{t.quote}</span>
            <strong>El plan era simple. El humano sigue recuperándose.</strong>
        </p>
    </div>
</section>
