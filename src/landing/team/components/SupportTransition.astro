---
import type { KnownLocale } from '../../../types';
import '../styles/SupportTransition.css';

interface Props {
    locale: KnownLocale;
    t: {
        eyebrow: string;
        title: string;
        text: string;
        linkText: string;
        inbox: {
            ideas: string;
            bugs: string;
            fixes: string;
            support: string;
        };
    };
}

const { locale, t } = Astro.props;
const supportHref = `/${locale}/support`;
---

<section class="team-section support-transition" aria-labelledby="support-transition-title">
    <div class="team-landing-inner support-transition-grid">
        <div>
            <p class="team-section-eyebrow">{t.eyebrow}</p>
            <h2 class="team-section-title" id="support-transition-title">{t.title}</h2>
            <p class="team-section-text">
                {t.text}
            </p>
            <a class="support-transition-link" href={supportHref}>{t.linkText}</a>
        </div>
        <div class="support-transition-inbox" aria-hidden="true">
            <span>{t.inbox.ideas}</span>
            <span>{t.inbox.bugs}</span>
            <span>{t.inbox.fixes}</span>
            <span>{t.inbox.support}</span>
        </div>
    </div>
</section>
